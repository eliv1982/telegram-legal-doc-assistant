# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# TTS: gtts или openai (OpenAI TTS требует подписки)
TTS_PROVIDER=gtts

# Таймаут ожидания второго сообщения (минуты)
SESSION_TIMEOUT_MINUTES=10

# Формат чек-листа: pdf или png
CHECKLIST_FORMAT=pdf

# Порог confidence (0-100): при меньшем значении — запрос перезагрузки или fallback-OCR для PDF
CONFIDENCE_THRESHOLD=70
